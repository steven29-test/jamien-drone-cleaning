{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "Stage": true
    }
  },
  "rewrites": [
    {
      "source": "/(?!.*\\.(?:js|css|svg|png|jpg|jpeg|gif|mp4|txt|xml|json|webp)$)(.*)",
      "destination": "/index.html"
    }
  ]
}
